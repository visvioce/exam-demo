@startuml

' ─────────────────────────────────────────────
'  学生登录时序图 — Black & White Style
'  南方职业学院在线考试系统
' ─────────────────────────────────────────────

!theme plain
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName "monospace"
skinparam defaultFontSize 11
skinparam sequenceMessageAlign center
skinparam ArrowColor #000000
skinparam ArrowThickness 1.5
skinparam LifeLineBorderColor #888888
skinparam LifeLineBackgroundColor #FFFFFF
skinparam ParticipantBorderColor #000000
skinparam ParticipantBackgroundColor #FFFFFF
skinparam ParticipantFontColor #000000
skinparam ActorBorderColor #000000
skinparam ActorBackgroundColor #FFFFFF
skinparam ActorFontColor #000000
skinparam SequenceBoxBorderColor #000000
skinparam SequenceBoxBackgroundColor #FFFFFF
skinparam NoteBorderColor #000000
skinparam NoteBackgroundColor #FFFFFF

title <size:16><b>学生登录时序图</b></size>\n<size:11>南方职业学院在线考试系统  |  Vue3 + Spring Boot + MyBatis + JWT</size>

actor "学生\n(Student)" as Student
participant "Login.vue\n(前端页面)" as LoginVue
participant "auth.ts\n(Pinia Store)" as AuthStore
participant "auth.ts\n(API 层)" as AuthApi
participant "AuthController\n(控制器)" as AuthController
participant "UserService\n(服务层)" as UserService
participant "UserMapper\n(数据层)" as UserMapper
database "MySQL\n(数据库)" as MySQL
participant "JwtUtil\n(JWT 工具)" as JwtUtil

' ═══ 步骤1-2: 表单输入与验证 ═══
Student -> LoginVue : 1. 输入用户名密码
LoginVue -> LoginVue : 2. 表单验证 (Element Plus)

' ═══ 步骤3-4: Store 与 API 调用 ═══
LoginVue -> AuthStore : 3. login(credentials)
AuthStore -> AuthApi : 4. login(data)

' ═══ 步骤5-6: HTTP 请求到后端 ═══
AuthApi -> AuthController : 5. POST /api/auth/login
AuthController -> UserService : 6. login(username, password)

' ═══ 步骤7-8: 数据库查询 ═══
UserService -> UserMapper : 7. selectByUsername(username)
UserMapper -> MySQL : 8. SELECT * FROM users\nWHERE username=? AND deleted=0
MySQL --> UserMapper : 返回用户数据
UserMapper --> UserService : 返回 User 对象

' ═══ 外层 alt: 用户存在性检查 ═══
group alt [用户是否存在]

    group #FFEEEE [用户不存在]
        UserService -> UserService : <color:red>BusinessException("用户不存在")</color>
        UserService --> AuthController : 异常
        AuthController --> AuthApi : 400 错误响应
        AuthApi --> AuthStore : 登录失败
        AuthStore --> LoginVue : return false
        LoginVue --> Student : <color:red>显示错误提示</color>
    end

else 用户存在
    ' ═══ 步骤9: 密码验证 ═══
    UserService -> UserService : 9. PasswordUtil.matches()\n验证密码 (BCrypt)

    group alt [密码验证]

        group #FFEEEE [密码错误]
            UserService -> UserService : <color:red>BusinessException("密码错误")</color>
            UserService --> AuthController : 异常
            AuthController --> AuthApi : 400 错误响应
            AuthApi --> AuthStore : 登录失败
            AuthStore --> LoginVue : return false
            LoginVue --> Student : <color:red>显示错误提示</color>
        end

    else 密码正确
        ' ═══ 步骤10: 用户状态检查 ═══
        UserService -> UserService : 10. 检查用户状态 (ACTIVE)

        group alt [状态检查]

            group #FFEEEE [用户被禁用]
                UserService -> UserService : <color:red>BusinessException("用户已被禁用")</color>
                UserService --> AuthController : 异常
                AuthController --> AuthApi : 400 错误响应
                AuthApi --> AuthStore : 登录失败
                AuthStore --> LoginVue : return false
                LoginVue --> Student : <color:red>显示错误提示</color>
            end

        else 状态正常
            ' ═══ 步骤11: JWT Token 生成 ═══
            UserService -> JwtUtil : 11. generateToken(userId, username, role)
            JwtUtil --> UserService : 返回 JWT Token

            ' ═══ 步骤12: 构建响应 ═══
            UserService -> UserService : 12. 构建 LoginResponse\n(token + userInfo)
            UserService --> AuthController : 返回 LoginResponse

            ' ═══ 响应层层返回 ═══
            AuthController --> AuthApi : Result.success(LoginResponse)
            AuthApi --> AuthStore : 返回响应数据

            ' ═══ 步骤13-15: 前端状态更新 ═══
            AuthStore -> AuthStore : 13. 存储 token 到 localStorage
            AuthStore -> AuthStore : 14. 更新 Pinia 状态 (token + user)
            AuthStore -> AuthStore : 15. ElMessage.success('登录成功')
            AuthStore --> LoginVue : return true

            ' ═══ 步骤16: 页面跳转 ═══
            LoginVue -> LoginVue : 16. router.push('/dashboard')
            LoginVue --> Student : <color:green>登录成功，跳转首页</color>

        end
    end
end

footer 南方职业学院 © 2026  |  架构: 前后端分离  |  安全: BCrypt + JWT + 软删除
@enduml
