@startuml

' ─────────────────────────────────────────────
'  图3.3 学生答题与成绩评定活动图 — Black & White Style
'  南方职业学院在线考试系统
'  描述学生进入考试、在线答题、提交试卷，
'  以及系统对客观题自动评分、主观题人工阅卷的完整流程
' ─────────────────────────────────────────────

!theme plain
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName "monospace"
skinparam defaultFontSize 11
skinparam ArrowColor #000000
skinparam ArrowThickness 1.5
skinparam ActivityBorderColor #000000
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityFontColor #000000
skinparam ActivityDiamondBorderColor #000000
skinparam ActivityDiamondBackgroundColor #FFFFFF
skinparam ActivityDiamondFontColor #000000
skinparam ActivityStartColor #000000
skinparam ActivityEndColor #000000
skinparam ActivityBarColor #000000

title <size:16><b>图3.3 学生答题与成绩评定活动图</b></size>\n<size:11>南方职业学院在线考试系统  |  学生：进入考试 → 答题 → 提交 → 系统自动评分客观题 → 教师人工阅卷主观题</size>

' ═══════════════════════════════════════════════
'  阶段一: 学生查看考试并开始
' ═══════════════════════════════════════════════

start

:学生登录系统，进入「我的考试」;

:GET /api/exams/my
获取已发布的考试列表
附带 studentExamStatus;

:展示考试列表
显示各考试的
- 名称、课程、时间、时长
- 个人状态: 未开始 / 进行中 / 已提交;

if (选择考试?) then (<color:green>点击「开始考试」</color>)

  partition "【开始考试】POST /api/exams/{id}/start" {

    :ExamService.startExam(examId, studentId);

    if (考试状态校验?) then (<color:red>失败</color>)
      :<color:red>异常终止
      - 考试不存在
      - 考试未发布（状态不是PUBLISHED/STARTED）
      - 未加入对应课程;
      stop
    else (<color:green>通过</color>)
    endif

    if (时间校验?) then (<color:red>失败</color>)
      :<color:red>异常终止
      - 考试时间未设置
      - 考试尚未开始 (now < startedAt)
      - 考试已结束 (now > endedAt + 30s);
      stop
    else (<color:green>通过</color>)
    endif

    if (是否已参加过?) then (<color:red>是</color>)
      if (当前状态?) then (<color:red>已提交 SUBMITTED/GRADED</color>)
        :<color:red>BusinessException
        "已参加过该考试";
        stop
      else (<color:green>进行中 IN_PROGRESS</color>)
        :返回现有 session
        继续之前的考试;
      endif
    else (<color:green>否 — 首次参加</color>)
      :创建 ExamSession
      - session.studentId = studentId
      - session.examId = examId
      - session.status = IN_PROGRESS
      - session.startedAt = now
      - session.totalScore = exam.totalScore

      INSERT INTO exam_sessions

      防重复: 乐观锁 + DuplicateKeyException 处理;
    endif
  }

  :跳转到答题页面;
  
else (<color:green>点击「查看回顾」(已交卷)</color>)
  --> 跳转到阶段六 (查看成绩)
endif

' ═══════════════════════════════════════════════
'  阶段二: 加载题目并开始答题
' ═══════════════════════════════════════════════

partition "【获取题目】GET /api/exams/{id}/questions" {

  :ExamService.getExamQuestions(examId, studentId);

  :校验课程成员身份
  CourseService.isCourseMember();
  
  :校验考试状态 (PUBLISHED/STARTED);

  :校验时间范围
  startedAt < now < endedAt + 30s;

  :校验考试会话状态
  - session 必须存在
  - session.status 必须为 IN_PROGRESS;

  :校验是否超时
  now < session.startedAt + exam.duration;

  :获取试卷题目ID列表
  PaperService.getById(paperId)
  → 提取 paper.questions[].questionId;

  :批量查询题目
  QuestionService.listByIds(questionIds);

  :转换为考试题目响应
  QuestionForExamResponse.from(question)
  ** 移除正确答案和解析 **
  仅返回题目内容和选项;

}

partition "【在线答题界面】ExamTake.vue" {

  :展示考试信息头部
  - 考试标题
  - 总分 / 及格分
  - 题目数量
  - 倒计时器 (ElCountdown);

  :展示各题型答题区;

  repeat
    :学生逐题作答;

    note right
      <b>支持的题型:</b>
      · 单选题 (SINGLE_CHOICE) — Radio
      · 多选题 (MULTIPLE_CHOICE) — Checkbox
      · 判断题 (TRUE_FALSE) — Radio
      · 填空题 (FILL_BLANK) — 多个Input
      · 简答题 (ESSAY) — Textarea
    end note

    :答题卡实时更新
    已答题目标记为绿色;

    partition "【自动保存】每30秒触发" {
      :PUT /api/exams/{id}/auto-save
      ExamService.autoSaveExam();

      :校验:
      - 考试已发布
      - 考试未结束
      - 未超时
      - session.status = IN_PROGRESS;

      :UPDATE exam_sessions
      SET answers = ?
      (仅更新answers字段);

      :前端显示 "已保存 {时间}";
    }

  repeat while (考试时间未到 and 未提交?) is (<color:green>继续答题</color>)
  -> (<color:green>时间到 或 点击提交</color>);


}

' ═══════════════════════════════════════════════
'  阶段三: 提交试卷
' ═══════════════════════════════════════════════

partition "【提交考试】POST /api/exams/{id}/submit" {

  :学生点击「提交试卷」;

  :弹出确认对话框
  提示 "您还有 N 道题未作答";

  if (确认提交?) then (<color:red>取消</color>)
    :返回继续作答;
    detach
  else (<color:green>确认</color>)
  endif

  :ExamService.submitExam(examId, studentId, answers);

  :提交前校验
  - 考试状态 PUBLISHED/STARTED
  - session 存在且状态为 IN_PROGRESS
  - 考试未结束 (now < endedAt + 30s)
  - 未超时 (now < startedAt + duration);

  :validateAnswers(answers)
  验证答案格式;
  
  :normalizeSubmittedAnswers(answers)
  标准化提交的答案;

  :批量加载题目 (含正确答案)
  QuestionService.listByIds(questionIds);

  :验证答案的题目归属
  validateAnswerQuestionIds(answers, paperQuestionIds);

  :<b>【自动评分客观题】</b>;

  partition "客观题评分逻辑" {
    repeat :逐题评分;

      if (是客观题?) then (<color:green>是 (单选/多选/判断/填空)</color>)

        if (单选题 SINGLE_CHOICE?) then (<color:green>是</color>)
          :checkAnswer()
          忽略大小写比较
          studentAnswer.trim().equalsIgnoreCase(correctAnswer)
          → isCorrect = true/false;
        else (<color:green>否</color>)
        endif

        if (多选题 MULTIPLE_CHOICE?) then (<color:green>是</color>)
          :checkAnswer()
          JSON数组排序后比较
          studentAnswers.sort() == correctAnswers.sort()
          → isCorrect = true/false;
        else (<color:green>否</color>)
        endif

        if (判断题 TRUE_FALSE?) then (<color:green>是</color>)
          :normalizeTrueFalseAnswer()
          A/正确/true → TRUE
          B/错误/false → FALSE
          标准化后比较
          → isCorrect = true/false;
        else (<color:green>否</color>)
        endif

        if (填空题 FILL_BLANK?) then (<color:green>是</color>)
          :isFillBlankAnswerCorrect()
          1. 文本标准化 (去空格/全半角/大小写)
          2. 多答案匹配 (JSON数组/分隔符)
          3. 数值等价判断 (BigDecimal比较)
          → isCorrect = true/false;
        else (<color:green>否</color>)
        endif

        if (客观题 且 回答正确?) then (<color:green>是</color>)
          :score = 题目分值
          gradingStatus = GRADED;
        else (<color:red>否 — 回答错误</color>)
          :score = 0
          gradingStatus = GRADED;
        endif

      else (<color:green>否 — 主观题 ESSAY</color>)
        :主观题，跳过自动评分
        gradingStatus = PENDING (待评分)
        score = null
        isCorrect = null;
      endif

    repeat while (还有未处理题目?) is (<color:green>是</color>)
    -> (<color:green>全部处理完毕</color>);
  }

  :累加客观题得分
  objectiveScore = Σ(客观题得分);

  if (试卷中包含主观题?) then (<color:green>是</color>)
    :session.status = SUBMITTED (已提交)
    session.gradingStatus = PENDING (待评分)
    主观题等待教师批阅;
  else (<color:green>否 — 全客观题</color>)
    :session.status = GRADED (已评分)
    session.gradingStatus = COMPLETED (评分完成)
    总分 = objectiveScore;
  endif

  :UPDATE exam_sessions
  (乐观锁 version 校验，防重复提交);
}

' ═══════════════════════════════════════════════
'  阶段四: 时间到自动提交
' ═══════════════════════════════════════════════

if (考试时间到 (倒计时结束)?) then (<color:green>是</color>)
  :前端 ElCountdown @finish
  自动触发 handleTimeUp();
  
  :调用提交接口
  POST /api/exams/{id}/submit
  携带当前已保存的答案;

  :后端处理同阶段三;
else (<color:green>否</color>)
endif

' ═══════════════════════════════════════════════
'  阶段五: 教师批阅主观题
' ═══════════════════════════════════════════════

if (试卷有主观题 且 已提交?) then (<color:green>是</color>)

  partition "【教师人工阅卷】POST /api/exam-sessions/grade" {

    :教师进入「考试批改」页面;

    :查看待批阅学生列表
    gradingStatus = PENDING 的 session;

    :选择学生答卷进行批阅;

    :ExamService.gradeSubjectiveAnswers(operatorId, role, request);

    :校验权限
    - ADMIN 或 考试创建教师;

    :校验会话状态
    - session.status = SUBMITTED
    - session.gradingStatus = PENDING;

    repeat :逐个主观题打分;

      :校验评分数据
      - questionId 存在
      - score 不为 null
      - score ≤ 该题满分 (maxScore)
      - score ≥ 0;

      :确认题目类型为主观题 (ESSAY);

      :设置评分结果
      answer.score = 教师打分
      answer.teacherComment = 教师评语(可选)
      answer.gradingStatus = GRADED
      answer.isCorrect = (score > 0);

    repeat while (还有主观题未评分?) is (<color:green>是</color>)
    -> (<color:green>全部主观题评分完毕</color>);

    :校验所有主观题均已评分
    allEssayGraded = true;

    :计算最终总分
    objectiveScore = session.score (已有)
    subjectiveScore = Σ(主观题得分)
    finalScore = objectiveScore + subjectiveScore;

    :UPDATE exam_sessions
    session.score = finalScore
    session.status = GRADED (已评分)
    session.gradingStatus = COMPLETED (评分完成)
    (乐观锁防并发);
  }

else (<color:green>否</color>)
endif

' ═══════════════════════════════════════════════
'  阶段六: 学生查看成绩与回顾
' ═══════════════════════════════════════════════

partition "【查看成绩】ExamReview.vue" {

  :学生进入「考试回顾」;

  :GET /api/exam-sessions/{id}/result
  ExamService.getExamResult();

  :权限校验
  - 学生本人
  - 或 ADMIN / 考试创建教师;

  :GET /api/exams/{id}/review-questions
  ExamService.getReviewQuestions()
  checkReviewPermission();

  :权限校验:
  - ADMIN: 任意查看
  - TEACHER: 只能查看自己创建的考试
  - STUDENT: 
    · 考试已结束(ENDED)
    · 或已提交(SUBMITTED/GRADED);

  :返回完整题目 (含答案+解析);

  :展示成绩与答题回顾;

  if (主观题状态?) then (<color:green>PENDING 待批阅</color>)
    :显示 "等待老师批阅"
    主观题暂不显示得分;

    if (教师已完成阅卷?) then (<color:green>GRADED</color>)
      :刷新后可查看
      主观题得分 + 评语
      最终总分;
    else (<color:green>尚未批阅</color>)
    endif

  else (<color:green>GRADED / COMPLETED</color>)
    :展示完整成绩信息
    - 客观题得分
    - 主观题得分 (如有)
    - 最终总分 / 满分
    - 每题正确/错误状态
    - 正确答案 + 解析
    - 教师评语 (主观题);

  endif

  :答题卡颜色标识
  · 绿色 = 正确
  · 红色 = 错误
  · 黄色 = 待批阅;
}

stop

footer 南方职业学院 © 2026  |  ExamSession 状态: NOT_STARTED → IN_PROGRESS → SUBMITTED → GRADED  |  Grading 状态: PENDING → GRADED → COMPLETED
@enduml