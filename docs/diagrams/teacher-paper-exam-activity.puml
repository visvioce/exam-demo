@startuml

' ─────────────────────────────────────────────
'  图3.2 组卷与考试管理活动图 — Black & White Style
'  南方职业学院在线考试系统
'  描述教师从选择组卷方式（手动/自动）生成试卷，
'  到创建考试、配置参数、发布考试、监控考试状态的完整流程
' ─────────────────────────────────────────────

!theme plain
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName "monospace"
skinparam defaultFontSize 11
skinparam ArrowColor #000000
skinparam ArrowThickness 1.5
skinparam ActivityBorderColor #000000
skinparam ActivityBackgroundColor #FFFFFF
skinparam ActivityFontColor #000000
skinparam ActivityDiamondBorderColor #000000
skinparam ActivityDiamondBackgroundColor #FFFFFF
skinparam ActivityDiamondFontColor #000000
skinparam ActivityStartColor #000000
skinparam ActivityEndColor #000000
skinparam ActivityBarColor #000000

title <size:16><b>图3.2 组卷与考试管理活动图</b></size>\n<size:11>南方职业学院在线考试系统  |  教师：组卷 → 创建考试 → 发布 → 监控状态</size>

' ═══════════════════════════════════════════════
'  阶段一: 组卷（手动组卷 / 自动组卷）
' ═══════════════════════════════════════════════

start

:教师登录系统，进入「试卷管理」;

:点击「创建试卷」;

if (选择组卷方式?) then (<color:green>手动组卷 MANUAL</color>)
  partition "【手动组卷】ManualPaperForm.vue" {
    :填写试卷基本信息
    (名称、课程、描述);

    :从题库中逐题选择题目
    设置每题的分值;

    :POST /api/papers
    PaperService.save(paper)
    paper.type = "MANUAL", status = "DRAFT";

    :试卷保存成功
    状态: 草稿 (DRAFT);
  }

else (<color:green>自动组卷 AUTO</color>)
  partition "【自动组卷】AutoPaperForm.vue" {
    :配置组卷规则
    - 选择题型 (单选/多选/判断/填空/简答)
    - 设置各题型数量
    - 设置各题型分值
    - 选择难度 (EASY/MEDIUM/HARD)
    - 选择知识点范围;

    :POST /api/papers/auto-generate
    PaperService.autoGenerate(request, teacherId);

    :系统按配置规则从题库随机抽题
    - 按 type/teacherId/subject/difficulty 筛选
    - Collections.shuffle() Fisher-Yates 洗牌
    - 校验题库题目数量是否足够;

    if (题库题目不足?) then (<color:red>是</color>)
      :<color:red>BusinessException
      "题库中该类型题目不足"
      提示当前数量与需求数量;
      stop
    else (<color:green>否</color>)
    endif

    :构建 Paper 对象
    计算总分 totalScore
    paper.type = "AUTO"
    paper.status = "DRAFT";

    :自动组卷成功
    状态: 草稿 (DRAFT);
  }
endif

' ═══════════════════════════════════════════════
'  阶段二: 创建考试
' ═══════════════════════════════════════════════

partition "【创建考试】ExamList.vue → ExamController" {
  :点击「创建考试」;

  :选择试卷 (paperId)
  系统自动同步试卷总分 totalScore;

  :选择所属课程 (courseId);

  :填写考试名称 (title);

  :配置考试参数
  - 开始时间 (startedAt)
  - 结束时间 (endedAt)
  - 考试时长 (duration, 分钟)
  - 及格分 (passScore)
  - 考试说明 (description, 可选);

  :POST /api/exams
  ExamService.createExam(examRequest, teacherId);

  :校验试卷有效性
  PaperService.getById(paperId)
  从试卷获取 totalScore;

  :保存考试
  exam.status = "DRAFT"
  考试创建成功 (草稿状态);
}

' ═══════════════════════════════════════════════
'  阶段三: 编辑考试（仅草稿状态可编辑）
' ═══════════════════════════════════════════════

if (需要编辑考试?) then (<color:green>是 — 仅DRAFT状态</color>)
  partition "【编辑考试】ExamController" {
    :PUT /api/exams/{id}
    ExamService.updateExam(id, request, userId, role);

    if (当前状态 == DRAFT?) then (<color:green>是</color>)
      :允许修改全部字段
      试卷、课程、时间、时长
      变更试卷时重新同步总分;
    else (<color:red>否</color>)
      :<color:red>锁定关键字段
      试卷、课程、时间、分值
      防止发布后被篡改;
    endif
  }
else (<color:green>否</color>)
endif

' ═══════════════════════════════════════════════
'  阶段四: 发布考试
' ═══════════════════════════════════════════════

partition "【发布考试】ExamController.publishExam()" {
  :POST /api/exams/{id}/publish;

  :权限校验
  checkOwnership(id, userId, role);

  :状态校验
  - status 必须为 DRAFT;

  if (考试时间是否有效?) then (<color:red>否</color>)
    :<color:red>BusinessException
    "请先设置考试开始和结束时间"
    或 "开始时间必须早于结束时间";
    stop
  else (<color:green>是</color>)
  endif

  :UPDATE exams
  SET status = "PUBLISHED";

  :考试发布成功
  学生端可见;

}

' ═══════════════════════════════════════════════
'  阶段五: 考试状态监控与流转
' ═══════════════════════════════════════════════

partition "【考试状态生命周期监控】" {

  :考试状态流转: DRAFT → PUBLISHED → STARTED → ENDED;

  :<b>DRAFT (草稿)</b>
  教师可操作:
  · 编辑考试 (修改全部字段)
  · 发布考试 → PUBLISHED
  · 删除考试 (前提: 无学生参加记录);

  :<b>PUBLISHED (已发布)</b>
  学生端可见此考试;

  if (时间到达 startedAt?) then (<color:green>是</color>)
    :系统 applyCurrentStatus()
    状态自动变为 <b>STARTED (进行中)</b>;
  else (<color:red>否 — 教师取消</color>)
    :POST /api/exams/{id}/cancel
    状态变为 <b>CANCELLED (已取消)</b>;
    note right
      仅 DRAFT 或 PUBLISHED
      状态可取消
    end note
  endif

  :<b>STARTED (进行中)</b>
  学生正在答题;

  if (时间到达 endedAt?) then (<color:green>是</color>)
    :系统 applyCurrentStatus()
    状态自动变为 <b>ENDED (已结束)</b>;
  else (<color:red>否 — 教师取消</color>)
    :POST /api/exams/{id}/cancel
    状态变为 <b>CANCELLED (已取消)</b>;
  endif

  :<b>ENDED (已结束)</b>
  · 不可再作答
  · 教师可查看成绩 / 批阅主观题;

  if (状态变为 CANCELLED?) then (<color:red>是</color>)
    :<b>CANCELLED (已取消)</b>
    终态，不可恢复;
  else (<color:green>否</color>)
  endif

}

' ═══════════════════════════════════════════════
'  阶段六: 教师后续操作
' ═══════════════════════════════════════════════

if (考试结束?) then (<color:green>是 (ENDED)</color>)

  partition "【教师阅卷】ExamService" {

    if (有主观题需要批阅?) then (<color:green>是</color>)
      :教师进入「考试批改」;

      :查看学生答卷
      gradingStatus = PENDING 的记录;

      :逐个主观题打分
      POST /api/exam-sessions/grade
      ExamService.gradeSubjectiveAnswers()
      
      校验:
      - 得分 ≤ 满分
      - 得分 ≥ 0
      - 所有主观题必须全部评分;

      :计算总分 = 客观题分 + 主观题分
      session.status = GRADED (已评分)
      session.gradingStatus = COMPLETED (评分完成);

      :学生可查看最终成绩与解析;

    else (<color:green>否 — 全客观题</color>)
      :无需人工阅卷
      提交时已自动完成评分
      session.status = GRADED;
    endif
  }

else (<color:green>否</color>)
endif

stop

footer 南方职业学院 © 2026  |  考试状态枚举: DRAFT → PUBLISHED → STARTED → ENDED → (CANCELLED)  |  数据隔离: 教师仅操作自己数据
@enduml